    if (targetCompObj) {
      changeCompany(targetCompObj);
    }
  };

  return (
    <header className="bg-white border-b border-slate-200 md:h-16 h-auto flex flex-col md:flex-row items-center justify-between px-4 md:px-6 z-10 shrink-0 py-3 md:py-0">
